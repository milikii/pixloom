# Optional fallback auth for local or LAN-only access.
# Public access should use nginx or a unified auth service instead.
GRADIO_AUTH_USER=
GRADIO_AUTH_PASS=

# Runtime limits
PIXLOOM_MAX_INPUT_SIDE=2048
PIXLOOM_MAX_OUTPUT_SIDE=8192
PIXLOOM_MAX_UPLOAD_BYTES=26214400
PIXLOOM_TILE_SIZE=256
PIXLOOM_TILE_OVERLAP=16
